{
  "expo": {
    "name": "Tracker",
    "slug": "tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tracker",
    "userInterfaceStyle": "automatic",

    "android": {
      "package": "com.ozion.tracker",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundImage": "./assets/images/background-icon.png",
        "foregroundImage": "./assets/images/foreground-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2d38c054-9392-4773-a565-3e3d3a82de11"
      }
    }
  }
}
